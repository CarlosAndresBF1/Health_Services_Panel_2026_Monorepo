# ─────────────────────────────────────────────────────────────────────────────
# HealthPanel - Variables de entorno requeridas (Laravel)
# Agrega estas variables al .env de tu proyecto Laravel.
# Los valores de MONITOR_API_KEY y MONITOR_SECRET deben coincidir con los
# configurados en el panel de HealthPanel al registrar este servicio.
# ─────────────────────────────────────────────────────────────────────────────

# [Requerido] API Key asignada al servicio en HealthPanel
MONITOR_API_KEY=

# [Requerido] Secret compartido para firmar las peticiones (HMAC-SHA256)
MONITOR_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Configuración de logs
# ─────────────────────────────────────────────────────────────────────────────

# [Opcional] Ruta al archivo de logs de la aplicación
# Por defecto: storage/logs/laravel.log
#
# Opciones disponibles:
# 1. Ruta estática: storage/logs/laravel.log
# 2. Patrón glob (busca el más reciente): storage/logs/laravel-*.log
# 3. Ruta absoluta: /var/www/miapp/storage/logs/laravel-2026-03-05.log
#
# Ejemplos:
MONITOR_LOG_FILE=storage/logs/laravel.log
# MONITOR_LOG_FILE=storage/logs/laravel-*.log
# MONITOR_LOG_FILE=/var/www/api-ejecucion-sin-limites.sinlimite2022.com/storage/logs/laravel-2026-03-05.log

# [Opcional] Modo de rotación de logs
# Valores: null (desactivado), daily (auto-detecta log diario de Laravel)
#
# Si tu proyecto Laravel usa LOG_CHANNEL=daily (archivos como laravel-2026-03-05.log),
# establece esto a 'daily' para auto-detectar el archivo más reciente.
#
# NOTA: Si usas MONITOR_LOG_ROTATION=daily, MONITOR_LOG_FILE se ignora.
MONITOR_LOG_ROTATION=

# ─────────────────────────────────────────────────────────────────────────────
# Configuración recomendada según tu LOG_CHANNEL de Laravel:
# ─────────────────────────────────────────────────────────────────────────────
#
# Si LOG_CHANNEL=single:
#   MONITOR_LOG_FILE=storage/logs/laravel.log
#   MONITOR_LOG_ROTATION=
#
# Si LOG_CHANNEL=daily:
#   MONITOR_LOG_FILE=
#   MONITOR_LOG_ROTATION=daily
#
# Si LOG_CHANNEL=stack (con daily):
#   MONITOR_LOG_FILE=storage/logs/laravel-*.log
#   MONITOR_LOG_ROTATION=
# ─────────────────────────────────────────────────────────────────────────────
