{
  "name": "healthpanel",
  "version": "2.3.0",
  "private": true,
  "description": "HealthPanel - Website monitoring dashboard",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:panel": "pnpm --filter=@healthpanel/panel run dev",
    "dev:api": "pnpm --filter=@healthpanel/api run dev",
    "build": "pnpm -r run build",
    "build:panel": "pnpm --filter=@healthpanel/panel run build",
    "build:api": "pnpm --filter=@healthpanel/api run build",
    "start": "pnpm -r --parallel run start",
    "start:panel": "pnpm --filter=@healthpanel/panel run start",
    "start:api": "pnpm --filter=@healthpanel/api run start",
    "test": "pnpm -r run test",
    "test:panel": "pnpm --filter=@healthpanel/panel run test",
    "test:api": "pnpm --filter=@healthpanel/api run test",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "clean:dist": "pnpm -r run clean",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:build": "docker compose build",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "docker:prod:build": "docker compose -f docker-compose.prod.yml build",
    "migration:generate": "pnpm --filter=@healthpanel/api run migration:generate",
    "migration:run": "pnpm --filter=@healthpanel/api run migration:run",
    "migration:revert": "pnpm --filter=@healthpanel/api run migration:revert",
    "seed:run": "pnpm --filter=@healthpanel/api run seed:run"
  },
  "devDependencies": {},
  "dependencies": {}
}
