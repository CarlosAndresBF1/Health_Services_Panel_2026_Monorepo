# ─── Puertos ─────────────────────────────────────────────────────────────────
# Puerto del panel (Next.js frontend)
PORT_PANEL=3044
# Puerto de la API (NestJS backend) — en producción solo se usa para WebSocket
PORT_API=3045
# Puerto de la base de datos PostgreSQL (mapeado al host)
PORT_DB=5433

# ─── App ──────────────────────────────────────────────────────────────────────
# Entorno de ejecución: development | production | test
NODE_ENV=development
# URL pública del panel frontend
PANEL_URL=http://localhost:3044
# URL pública del WebSocket (solo necesario para NEXT_PUBLIC_WS_URL en el panel)
# En producción, apunta a tu dominio o IP pública con el puerto del API
WS_URL=ws://localhost:3045

# ─── Base de datos ────────────────────────────────────────────────────────────
# Host del servicio PostgreSQL (nombre del servicio en docker-compose)
DB_HOST=postgres
# Puerto interno de PostgreSQL dentro de la red Docker
DB_PORT=5433
# Usuario de la base de datos
DB_USERNAME=healthpanel
# Contraseña de la base de datos (cambiar en producción)
DB_PASSWORD=healthpanel_secret
# Nombre de la base de datos
DB_DATABASE=healthpanel

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Secreto para firmar los JWT (mínimo 32 caracteres, cambiar en producción)
JWT_SECRET=your-jwt-secret-change-in-production
# Clave AES-256 para cifrar secretos almacenados en la base de datos (32 bytes en hex)
ENCRYPTION_KEY=your-aes-256-key-for-secrets-in-db

# ─── SendGrid ─────────────────────────────────────────────────────────────────
# API Key de SendGrid para el envío de alertas por email
SENDGRID_API_KEY=SG.xxxxx
# Dirección de email remitente para las alertas
ALERT_EMAIL_FROM=monitor@yourdomain.com
# Dirección de email destinatario de las alertas
ALERT_EMAIL_TO=admin@yourdomain.com

# ─── Monitor ──────────────────────────────────────────────────────────────────
# Intervalo de verificación por defecto en segundos
DEFAULT_CHECK_INTERVAL=60
# Tiempo máximo de espera para capturas de pantalla en milisegundos
SCREENSHOT_TIMEOUT=15000

# ─── Test User (seeder) ───────────────────────────────────────────────────────
# Usuario administrador inicial creado por el seeder
SEED_USER=admin
# Contraseña del usuario administrador inicial (cambiar en producción)
SEED_PASSWORD=admin123
