FROM node:22-alpine

LABEL org.opencontainers.image.title="HealthPanel Panel (Dev)"
LABEL org.opencontainers.image.description="HealthPanel Next.js monitoring dashboard - development"

WORKDIR /app

# Install dependencies first (layer caching)
COPY package.json package-lock.json* ./
RUN npm install

# Copy source files
COPY . .

EXPOSE 3000

ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1

CMD ["npm", "run", "dev"]
